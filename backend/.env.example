NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/hms_pro / Your Choice

# Application Settings
JWT_SECRET=Create Secret Key

CORS_ORIGIN=http://localhost:5173

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000 / Your Choice
RATE_LIMIT_MAX=100 / Your Choice
BCRYPT_SALT_ROUNDS=12 / Your Choice

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_Your Test ID
RAZORPAY_KEY_SECRET=Your Razo secret Key
RAZORPAY_WEBHOOK_SECRET=HMS_PRO_WEBHOOK_2026 / Your Choice

# Hospital Information
HOSPITAL_NAME=HMS Pro Hospital / Your Choice
HOSPITAL_GSTIN=NOT_APPLICABLE / Your Choice
HOSPITAL_ADDRESS=123 Care Avenue, Bengaluru, India / Your Choice
HOSPITAL_EMAIL=YourEmail@gmail.com
HOSPITAL_PHONE=+ Your Number
INVOICE_STORAGE_DIR=storage/invoices 

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YourEmail@gmail.com
SMTP_PASS=Your Email App Password
SMTP_FROM="HMS Pro Billing <Your Email @gmail.com>"

# Seed Super Admin Credentials
SEED_SUPER_ADMIN_NAME=HMS Super Admin
SEED_SUPER_ADMIN_EMAIL=superadmin@hms.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
